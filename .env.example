# Massive Inventions — Public storefront env (TEMPLATE)
# ⚠️  Never commit your real .env. This .env.example IS safe to commit.

# In dev: leave empty. Vite proxies /api/* to http://localhost:4000.
# In prod (Vercel): set to your public backend URL.
# VITE_API_URL=https://api.your-domain.com

# Supabase (optional — for real Supabase Auth). Leave empty in dev mock mode.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Web3Forms — newsletter + contact form notifications.
# Get a free key at https://web3forms.com.
VITE_WEB3FORMS_KEY=
# Destination email (where notifications are forwarded).
VITE_WEB3FORMS_TO=you@example.com

# Razorpay public key (NOT the secret — the secret lives backend-side).
# Use rzp_test_xxx during development, rzp_live_xxx in production.
VITE_RAZORPAY_KEY_ID=