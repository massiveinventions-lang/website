# Massive Inventions — Backend env vars
#
# ⚠️  NEVER put real credentials in this file. This file is committed to
#     git and shared with every developer who clones the repo. Use it as
#     a TEMPLATE only.
#
# Setup:
#   1. Copy this file to `.env` (which is gitignored):
#        cp .env.example .env
#   2. Fill in your own credentials in `.env` only.
#   3. Leave any value blank to disable that integration. The corresponding
#      endpoint will still respond, but use a stub.
#
# Anything left blank disables the corresponding integration; endpoints still
# respond but use stubs.

# --- Server ---
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000

# --- MongoDB ---
# Free Atlas cluster: https://www.mongodb.com/cloud/atlas
# Local fallback: mongodb://127.0.0.1:27017/massive_inventions
MONGO_URI=

# --- Firebase Admin (for verifying ID tokens) ---
# 1. console.firebase.google.com → Project Settings → Service Accounts
# 2. Generate new private key, copy each field into your local `.env`
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Admin allowlist (comma-separated emails; bypasses DB user.role for first admin)
ADMIN_EMAILS=

# --- Razorpay ---
# Dashboard → Settings → API Keys
# Use TEST mode keys (rzp_test_...) during development.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Shiprocket ---
# apiv2.shiprocket.in → Settings → API
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_LOCATION=Home

# --- Cloudinary ---
# cloudinary.com → Console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
