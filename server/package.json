{
  "name": "massive-inventions-server",
  "version": "1.0.0",
  "description": "Massive Inventions e-commerce backend (Express + Prisma + PostgreSQL/Supabase + Razorpay + Shiprocket + Supabase Auth + Supabase Storage)",
  "main": "dist/index.js",
  "type": "commonjs",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "echo 'No build step needed — using tsx at runtime'",
    "start": "node --import tsx/esm src/index.ts",
    "seed": "tsx prisma/seed.ts",
    "smoke": "tsx src/scripts/smoke.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push --skip-generate",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.46.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "razorpay": "^2.9.5",
    "resend": "^6.16.0",
    "tsx": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "embedded-postgres": "^18.4.0-beta.17",
    "prisma": "^5.22.0",

    "typescript": "^5.6.3"
  }
}
