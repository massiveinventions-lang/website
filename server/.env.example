# Massive Inventions — Backend env (TEMPLATE — copy to .env)
# ⚠️  Never commit your real .env. This .env.example IS safe to commit.

# --- Server ---
PORT=4000
NODE_ENV=development
# Comma-separated allowed origins. Production must include your real domains.
CLIENT_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:5174

# Generate with: openssl rand -base64 48  OR  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-me-with-a-strong-random-string-at-least-32-chars

# --- Mock mode ---
# true  = run with no external accounts (uses local SQLite + Razorpay/Shiprocket mocks)
# false = use real Razorpay/Shiprocket
#
# ⚠️  Set to `true` ONLY for local development. Production MUST be
# `false` — otherwise the backend will accept any email as a valid
# bearer token and never call Razorpay or Shiprocket.
MOCK_INTEGRATIONS=false

# --- Database ---
# Local dev: SQLite file. Zero setup.
DATABASE_URL="file:./dev.db"
# Production: Supabase Postgres pooler string, e.g.:
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require"

# --- Supabase (Auth + Storage) ---
# Required for real Supabase Auth. Leave blank in dev mock mode (the URL
# must be present, even as a placeholder, to satisfy the client init).
SUPABASE_URL=https://mock.supabase.co
SUPABASE_ANON_KEY=mock_anon_key
SUPABASE_SERVICE_ROLE_KEY=mock_service_role_key
SUPABASE_STORAGE_BUCKET=products

# --- Admin ---
# Comma-separated emails allowed to log into /api/admin/login.
ADMIN_EMAILS=you@example.com
# Strong password used by /api/admin/login. Change before deploying.
ADMIN_PASSWORD=change-me

# --- Email (Resend) ---
# Sign up at https://resend.com — free tier gives 3,000 emails/month and
# 100 emails/day. Required for OTP delivery in production (so the user
# actually receives their code in their inbox, not just the server log).
RESEND_API_KEY="re_TwpsFqgC_84VLhqNajA5eq46Mxzyqvr6g"
# The "from" address shown in the email. Must be a verified domain in
# Resend, or use the sandbox "onboarding@resend.dev" for testing.
RESEND_FROM="Massive Inventions <onboarding@resend.dev>"

# --- Razorpay ---
# Get these from razorpay.com → Settings → API Keys (use test keys first).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Shiprocket ---
# Get these from shiprocket.in → Settings → API.
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
# Pickup location name as registered in Shiprocket (Settings → Pickup Locations).
# Must match exactly. The toggle next to the location in the Shiprocket
# dashboard must be ON, or the API will reject any order referencing it.
SHIPROCKET_PICKUP_LOCATION=Home
# Optional: Shiprocket sales-channel ID. The API rejects an empty
# channel_id on many accounts, causing "order not in dashboard" issues.
# Run `curl https://your-api/api/test-sr` after deploy — the response
# includes a `channels.sample` array. Copy the `id` of the channel
# you want orders to flow through (usually the first one).
SHIPROCKET_CHANNEL_ID=